# -----------------------------------------------------------------------------
# Traces on the Moon — public site URL (no secrets)
# -----------------------------------------------------------------------------
# Used for: metadataBase, canonical URLs, Open Graph URLs, sitemap.xml,
# robots.txt sitemap line, and JSON-LD absolute URLs.
#
# Production (moontraces.com) — set in the hosting dashboard (recommended), or
# uncomment for a local production-like build:
# NEXT_PUBLIC_SITE_URL=https://moontraces.com
#
# Local development — optional override (defaults to http://localhost:3000 when unset):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Vercel previews: omit NEXT_PUBLIC_SITE_URL to use VERCEL_URL, or set per environment.
